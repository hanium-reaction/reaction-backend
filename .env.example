# reaction-backend 환경변수 예시 (.env로 복사 후 사용)

# 실행 환경: local | dev | staging | prod
APP_ENV=local

# 앱 메타
APP_NAME=reaction-backend
APP_VERSION=0.1.0

# 서버 바인딩
HOST=0.0.0.0
PORT=8000

# CORS 허용 origin (JSON 배열로 입력)
CORS_ALLOW_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# CORS 패턴 매칭 (Vercel preview URL 등). 미사용이면 비워둔다.
# CORS_ALLOW_ORIGIN_REGEX=^https://reaction-frontend-.*\.vercel\.app$

# ───── DB (Issue #2) ─────

# Supabase Session pooler (Northeast Asia / Seoul) 권장
# 형태: postgresql://postgres.<project-ref>:<password>@aws-X-ap-northeast-2.pooler.supabase.com:5432/postgres
# 코드(db/session.py)가 자동으로 postgresql+asyncpg:// 로 변환합니다.
# 로컬 docker postgres로 개발 시: postgresql://reaction:reaction@localhost:5432/reaction
DATABASE_URL=

# SQL 쿼리 로그 (local 디버깅용). prod에선 반드시 false.
DB_ECHO=false

# ───── 후속 이슈에서 채워질 자리 ─────

# Issue #5 — LLM (Gemini)
# GEMINI_API_KEY=
# LLM_MODEL=gemini-2.0-flash-exp
# LLM_TIMEOUT_SECONDS=8
# LLM_MAX_RETRIES=3

# ───── Auth (Issue #16) ─────

# Google OAuth client — Google Cloud Console에서 발급한 web application client.
# FE/BE가 같은 client_id를 공유해야 id_token.aud 검증이 맞물린다.
# local 개발은 AUTH_STUB_MODE=true 로 우회 가능 (아래 참고).
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=  # SPA + id_token 흐름에서는 BE 미사용. server-side flow 대비 자리.
# GOOGLE_OAUTH_REDIRECT_URI=   # Issue #6 캘린더 OAuth 에서 사용 예정.

# JWT — HS256. SECRET 은 32+ bytes 랜덤: python -c "import secrets; print(secrets.token_hex(32))"
# JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_MINUTES=60
JWT_REFRESH_TOKEN_TTL_DAYS=14

# Local stub 모드 — Google id_token 검증 우회 + demo user 발급. staging/prod 는 반드시 false.
AUTH_STUB_MODE=true

# Encryption (calendar tokens, failure memos)
# COLUMN_ENCRYPTION_KEY=
